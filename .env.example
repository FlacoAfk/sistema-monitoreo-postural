# Copy this to .env and fill in your values

# Enable WebSocket server for mobile app
POSTURE_WS_ENABLED=true

# Public WebSocket URL for the QR code shown in the UI
# In production on Dockply: wss://YOUR_DOMAIN/ws
# In local dev: ws://192.168.1.2:8765
POSTURE_WS_URL=wss://YOUR_DOCKPLY_DOMAIN.com/ws

# Optional: override the models directory path
# POSTURE_MODELS_DIR=/app/models_trained
